# gen_svg_slide — API keys for AI backends
#
# Copy this file to .env and fill in the keys you need.
# At least one provider is required.

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Qwen / Tongyi Qianwen (OpenAI-compatible)
# Accepts either QWEN_API_KEY or DASHSCOPE_API_KEY
QWEN_API_KEY=sk-your-qwen-key-here
# DASHSCOPE_API_KEY=sk-your-dashscope-key-here
